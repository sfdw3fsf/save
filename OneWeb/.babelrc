{
  "sourceType": "unambiguous",
  "presets": [
    [
      //"env", 
      "@babel/preset-env",
      {
        "modules": false,
        "targets": {
          "browsers": ["> 1%", "last 2 versions", "not ie <= 8"]
        }
      }
    ],
    //"stage-2"
  ],
  "plugins": ["transform-vue-jsx", "@babel/plugin-transform-runtime"],
  "env": {
    "test": {
      "sourceType": "unambiguous",
      "presets": ["@babel/preset-env"]//["env", "stage-2"]
    }
  }
}
