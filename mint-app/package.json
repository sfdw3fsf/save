{
  "name": "mint-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.prod.json && vite build",
    "optimize-bundle": "vite optimize --force",
    "build:production": "env-cmd -f .env.production vite build --mode production",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --fix --ext ts,tsx",
    "prettier": "prettier --check \"src/**/(*.tsx|*.ts|*.css|*.scss)\"",
    "prettier:fix": "prettier --write \"src/**/(*.tsx|*.ts|*.css|*.scss)\"",
    "fix": "yarn lint:fix && yarn prettier:fix",
    "knip": "knip"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.6.0",
    "@mantine/core": "^7.12.2",
    "@mantine/dates": "^7.12.2",
    "@mantine/hooks": "^7.12.2",
    "@react-oauth/google": "^0.12.1",
    "@tanstack/react-query": "^5.40.1",
    "@tanstack/react-query-devtools": "^5.40.1",
    "@tippyjs/react": "^4.2.6",
    "@uidotdev/usehooks": "^2.4.1",
    "axios": "^1.7.2",
    "dayjs": "^1.11.13",
    "env-cmd": "^10.1.0",
    "framer-motion": "^11.3.28",
    "i18next": "^23.11.5",
    "notistack": "^3.0.1",
    "nprogress": "^0.2.0",
    "query-string": "^9.1.0",
    "react": "^18.3.1",
    "react-animated-counter": "^1.7.9",
    "react-big-calendar": "^1.14.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.51.5",
    "react-i18next": "^14.1.2",
    "react-icons": "^5.2.1",
    "react-kakao-login": "^2.1.1",
    "react-responsive": "^9.0.2",
    "react-responsive-carousel": "^3.2.23",
    "react-router-dom": "^6.23.1",
    "react-select": "^5.8.2",
    "react-slick": "^0.30.2",
    "react18-input-otp": "^1.1.4",
    "slick-carousel": "^1.8.1",
    "tailwind-merge": "^2.5.0",
    "tailwindcss": "^3.4.7",
    "tippy.js": "^6.3.7",
    "vite-plugin-style-import": "^2.0.0",
    "yup": "^1.4.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@julr/vite-plugin-validate-env": "^0.2.4",
    "@types/node": "^22.2.0",
    "@types/nprogress": "^0.2.0",
    "@types/react": "^18.3.3",
    "@types/react-big-calendar": "^1.8.11",
    "@types/react-dom": "^18.3.0",
    "@types/react-helmet": "^6.1.11",
    "@types/react-slick": "^0.23.13",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "axios": "^1.7.2",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "eslint-plugin-unused-imports": "^3.0.0",
    "knip": "^5.27.2",
    "postcss": "^8.4.40",
    "prettier": "^3.3.2",
    "sass": "^1.77.4",
    "typescript": "^5.5.4",
    "vite": "^5.2.13"
  },
  "packageManager": "yarn@1.22.22"
}
